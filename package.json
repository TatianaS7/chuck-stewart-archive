{
  "name": "chuck-stewart-archive",
  "version": "1.0.0",
  "description": "Tool for searching the archive for Chuck Stewart's photography",
  "scripts": {
    "server": "node server.js",
    "build": "vite build",
    "client": "vite --open",
    "dev": "vite --open",
    "preview": "vite preview",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "test:server": "vitest run --config vitest.config.js server/tests/",
    "test:e2e": "cd public && npx playwright test",
    "test:e2e:ui": "cd public && npx playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TatianaS7/chuck-stewart-archive.git"
  },
  "keywords": [
    "Photography"
  ],
  "author": "Tatiana Stewart",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TatianaS7/chuck-stewart-archive/issues"
  },
  "homepage": "https://github.com/TatianaS7/chuck-stewart-archive#readme",
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@azure/storage-blob": "^12.24.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "concurrently": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "papaparse": "^5.5.3",
    "pg-hstore": "^2.3.4",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.2",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "uuid": "^10.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "assert": "^2.1.0",
    "browserify-zlib": "^0.2.0",
    "cross-env": "^10.1.0",
    "crypto-browserify": "^3.12.0",
    "eslint": "^10.1.0",
    "events": "^3.3.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "playwright": "^1.58.2",
    "process": "^0.11.10",
    "querystring-es3": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "string_decoder": "^1.3.0",
    "supertest": "^7.2.2",
    "url": "^0.11.3",
    "util": "^0.12.5",
    "vite": "^7.1.5",
    "vitest": "^4.1.0",
    "vm-browserify": "^1.1.2"
  }
}
